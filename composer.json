{
    "name": "chanchullapp/chanchullapp",
    "description": "chanchullapp - sistema para normalizar precios de facturas con ia",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "illuminate/view": "^10.0",
        "illuminate/events": "^10.0",
        "jenssegers/blade": "^2.0",
        "bramus/router": "^1.6",
        "vlucas/phpdotenv": "^5.5"
    },
    "autoload": {
        "psr-4": {
            "app\\": "app/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "php scripts/install-tailwind.php"
        ],
        "post-update-cmd": [
            "php scripts/install-tailwind.php"
        ],
        "server": "php -S localhost:8000 -t public",
        "tailwind": "php scripts/tailwind.php --watch",
        "tailwind:build": "php scripts/tailwind.php"
    }
}
